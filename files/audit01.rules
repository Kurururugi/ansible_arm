# Первое правило – удаление всех правил
-D
## Размер буфера. Допускается его увеличение для загруженных систем
-b 8192
-a exclude,always -F msgtype=EOE
-i
## Аудит доступа к файлам паролей и групп, а также попытки их изменения
-w /etc/group -p wa -F auid!=4294967295 -k sysobj_access
-w /etc/passwd -p wa -F auid!=4294967295 -k sysobj_access
-w /etc/shadow -p wa -F auid!=4294967295 -k sysobj_access
-w /etc/login.defs -p wa -F auid!=4294967295 -k sysobj_access
-w /etc/securetty -p wa -F auid!=4294967295 -k sysobj_access
## Отслеживать доступ к системным каталогам
-w /boot/ -p wa -k system_obj_modification
-w /bin/ -p wa -k system_obj_modification
-w /sbin/ -p wa -k system_obj_modification
-w /usr/bin/ -p wa -k system_obj_modification
-w /usr/sbin/ -p wa -k system_obj_modification
## Отслеживать доступ к системному планировщику событий
-w /etc/cron.allow -p wa -k cron
-w /etc/cron.deny -p wa -k cron
-w /etc/cron.d -p wa -k cron
-w /etc/cron.daily -p wa -k cron
-w /etc/cron.hourly -p wa -k cron
-w /etc/cron.monthly -p wa -k cron
-w /etc/cron.weekly -p wa -k cron
-w /etc/crontab -p wa -k cron
-w /var/spool/cron/crontabs -k cron
## Отслеживать доступ к общим настройкам безопасности операционной системы
-w /etc/sysctl.conf -p wa -F auid!=4294967295 -k sysobj_access
-w /etc/ssh/sshd_config -p wa -F auid!=4294967295 -k sysobj_access
-w /etc/localtime -p wa -F auid!=4294967295 -k time_change
-a exit,always -F arch=b32 -F uid!=_chrony -F auid!=4294967295 -S adjtimex -S settimeofday -S stime -S clock_settime -F uid!=_chrony -F auid!=4294967295 -k time-change
-a exit,always -F arch=b64 -F uid!=_chrony -F auid!=4294967295 -S adjtimex -S settimeofday -S clock_settime -F uid!=_chrony -F auid!=4294967295 -k time-change
-a exit,always -F arch=b32 -F auid!=4294967295 -S mknod -S mount -S umount -S umount2 -S ptrace -F auid!=4294967295 -k mount
-a exit,always -F arch=b64 -F auid!=4294967295 -S mknod -S mount -S umount2 -S ptrace -F auid!=4294967295 -k mount
## Аудит доступа к системным объектам аудит gshadow
-w /etc/gshadow -p wa -k sysobj_access
## Отслеживать использование механизма повышения привилегий
-w /bin/su -p x -k priv_esc
-w /usr/bin/sudo -p x -k priv_esc
-w /etc/sudoers -p wa -k priv_esc
-w /etc/sudoers.d/ -p wa -k priv_esc
## Отслеживать операции выключения и перезагрузки
-w /sbin/shutdown -p x -k power
-w /sbin/poweroff -p x -k power
-w /sbin/reboot -p x -k power
-w /sbin/halt -p x -k power
## Отслеживать изменение параметров аудита
-w /etc/audit/auditd.conf -p wa -F auid!=4294967295 -k audit_change
-w /etc/audit/audit01.rules -p wa -F auid!=4294967295 -k audit_change
-w /etc/libaudit.conf -p wa -F auid!=4294967295 -k audit_change
-w /etc/audit/plugins.d/syslog.conf -p wa -F auid!=4294967295 -k audit_change
-w /etc/audit/audit.conf -p wa -F auid!=4294967295 -k audit_change
-w /etc/rsyslog.conf -p wa -F auid!=4294967295 -k audit_change
-w /etc/init.d/auditd -p wa -F auid!=4294967295 -k audit_change
## Файлы настройки pam
-w /etc/pam.d/common-password -p wa -k actions
-w /etc/pam.d/common-auth -p wa -k actions
-w /etc/pam.d/common-account -p wa -k actions
##Отслеживание факта модификации сетевых параметров
-a always,exit -F arch=b64 -S sethostname -S setdomainname -k system-locale
-a always,exit -F arch=b32 -S sethostname -S setdomainname -k system-locale
-w /etc/issue -p wa -k system-locale
-w /etc/issue.net -p wa -k system-locale
-w /etc/hosts -p wa -k system-locale
-w /etc/network/ -p wa -k system-locale
##Добавить логирование lastlog/faillog
-w /var/log/lastlog -p wa -k logins
## Логирование информации по сеансам
-w /var/run/utmp -p wa -k session
-w /var/log/btmp -p wa -k logins
## Аудит изменений прав доступа в системе
-a always,exit -F arch=b64 -S chmod -S fchmod -S fchmodat -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b32 -S chmod -S fchmod -S fchmodat -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b64 -S chown -S fchown -S fchownat -S lchown -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b32 -S chown -S fchown -S fchownat -S lchown -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b64 -S setxattr -S lsetxattr -S fsetxattr -S removexattr -S lremovexattr -S fremovexattr -F auid>=1000 -F auid!=4294967295 -k perm_mod
-a always,exit -F arch=b32 -S setxattr -S lsetxattr -S fsetxattr -S removexattr -S lremovexattr -S fremovexattr -F auid>=1000 -F auid!=4294967295 -k perm_mod
## Аудит удаления файлов пользователями
-a always,exit -F arch=b64 -S unlink -S unlinkat -S rename -S renameat -F auid>=1000 -F auid!=4294967295 -k delete
-a always,exit -F arch=b32 -S unlink -S unlinkat -S rename -S renameat -F auid>=1000 -F auid!=4294967295 -k delete
## Аудит загрузку и выгрузку модулей
-w /sbin/insmod -p x -k modules
-w /sbin/rmmod -p x -k modules
-w /sbin/modprobe -p x -k modules
-a always,exit -F arch=b64 -S init_module -S delete_module -k modules
-w /var/log/audit/ -p wra -k auditlog
## Аудит эталона контрольных сумм в Alpha.Security
# -w /opt/Automiq/Alpha.Security/alpha.security.ic_etalon.xml -p wa -F auid!=4294967295 -k audit_change
